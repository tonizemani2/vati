# predictthefuture — environment template
# Copy to .env and fill in ONLY when a paid/scale provider is actually wired (Phase 2+).
# Nothing here is needed for the foundation phase — the cockpit + engine run with zero secrets.
#
# RULE: the engine reads provider keys from THIS repo's env only. It must never read
# /Users/emizemani/orca97-v2/.env or any other repo's secrets. (CONSTITUTION rule 6)

# --- Scale-only LLM providers (default reasoning is Claude in-session; these are for bulk work) ---
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=
# DEEPINFRA_API_KEY=          # orca has a keyless setup; prefer keyless where possible
# OPENROUTER_API_KEY=         # cheap OCR models; pdftotext is the free fallback

# --- Search (Exa keyless works with no key from a home IP; key is fallback only) ---
# EXA_API_KEY=

# --- Proxies (OFF by default; only enable if a trusted source requires it) ---
# EVOMI_USER=
# EVOMI_PASS=
# EVOMI_HOST=
# EVOMI_PORT=

# --- Object storage (Cloudflare R2: S3-compatible, $0 egress) — for huge raw corpora ---
# Park bulk data (arXiv/S2ORC dumps, patent PDFs, OCR inputs) off local disk; pull back free.
# Create keys: Cloudflare dash → R2 → Manage R2 API Tokens → Object Read & Write on the bucket.
# R2_ACCOUNT_ID=51907f8debf45062b7a962b2247e80af
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=bucketzemani
# R2_ENDPOINT=https://51907f8debf45062b7a962b2247e80af.r2.cloudflarestorage.com

# --- Cost gate ---
# Batches with est cost ≤ this run automatically (logged 'approved'); larger ones block for
# `approve-cost`. 0 = strict (every spend blocks). Recommended once data-scaling: 500 ($5/batch).
COST_AUTO_APPROVE_CENTS=0
